# Supabase
# Auth → URL configuration → Redirect URLs must include:
#   http://localhost:3000/callback
#   https://<your-production-host>/callback
# (needed for email confirmation and password reset links)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# Required for API routes that call auth.admin (e.g. account deletion).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AI Provider
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
