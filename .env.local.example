# Supabase
# Auth → URL configuration → Redirect URLs must include:
#   http://localhost:3000/callback
#   https://<your-production-host>/callback
# (needed for email confirmation and password reset links)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either publishable (newer) or anon key — same value family from Supabase → API settings
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # alternative name; supported on Vercel
# Required for API routes that call auth.admin (e.g. account deletion).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AI Provider
ANTHROPIC_API_KEY=sk-ant-...

# App (public site origin — used for absolute links e.g. class roster invites)
# Optional alias: NEXT_PUBLIC_SITE_URL (same value). If neither is set, invites copy as relative paths.
NEXT_PUBLIC_APP_URL=http://localhost:3000
